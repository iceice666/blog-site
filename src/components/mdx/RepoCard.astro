---
interface Props {
  url: string;
  desc: string;
}
import { renderInlineMarkdown } from '../../lib/markdown';

const { url, desc } = Astro.props;
const display = url.replace(/^https?:\/\//, '');
const descHtml = await renderInlineMarkdown(desc);
---

<div class="article-repo">
  <div>
    <a href={url} class="url" target="_blank" rel="noopener noreferrer">{display}</a>
    <div class="repo-desc" set:html={descHtml} />
  </div>
  <span class="ext" aria-hidden="true">↗</span>
</div>
