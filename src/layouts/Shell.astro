---
import '../styles/global.css';
import { NAV_ITEMS, getBlogStats } from '../lib/content';
import { getGithubData } from '../lib/github';
import Sidebar from '../components/Sidebar.mdx';
import { site } from '../../config';

interface Props {
  title: string;
  activeKey: 'feed' | 'about' | 'friends' | 'archive';
  extraWindow?: { label: string };
  paneTitle: string;
  langHref?: string | null;
  description?: string;
  lang?: string;
  wide?: boolean;
}
const {
  title,
  activeKey,
  extraWindow,
  paneTitle,
  langHref = null,
  description = site.description,
  lang = 'en',
  wide = false,
} = Astro.props;

const stats = await getBlogStats();
const github = await getGithubData();

const activeNavItem = NAV_ITEMS.find((n) => n.key === activeKey)!;
const extraWindowIndex = Math.max(...NAV_ITEMS.map((item) => item.windowIndex)) + 1;
const windowIndex = extraWindow ? extraWindowIndex : activeNavItem.windowIndex;
const sidebarIndex = 0;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="tmux">
      <div class="status-bar top">
        <div class="session">justaslime</div>
        <div class="windows">
          {
            NAV_ITEMS.map((item) => {
              const isActive = item.key === activeKey && !extraWindow;
              return (
                <a href={item.href} class={`win${isActive ? ' active' : ''}`}>
                  {item.windowIndex}:{item.label}
                  {isActive ? '*' : ''}
                </a>
              );
            })
          }
          {extraWindow && <span class="win active">{extraWindowIndex}:{extraWindow.label}*</span>}
        </div>
        <div class="status-right">
          <button id="theme-toggle" class="chip mode" type="button" aria-label="toggle color theme">NORMAL</button>
          {
            langHref ? (
              <a href={langHref} class="chip">en/中</a>
            ) : (
              <span class="chip" aria-disabled="true">en/中</span>
            )
          }
        </div>
      </div>

      <div class="panes">
        <div class="pane-main">
          <div class="pane-title">{windowIndex}.0 — {paneTitle}</div>
          <div class="scroll-area">
            <div class={`reading${wide ? ' is-wide' : ''}`}>
              <slot />
            </div>
          </div>
        </div>

        <Sidebar windowIndex={sidebarIndex} stats={stats} github={github} />
      </div>

      <div class="status-bar bottom">
        <slot name="footer-hints">
          <span>j/k move</span><span>gg/G top/bottom</span><span>/ search</span><span>:q back</span>
        </slot>
      </div>
    </div>

    <script>
      (function () {
        const root = document.documentElement;
        const btn = document.getElementById('theme-toggle');
        btn?.addEventListener('click', function () {
          const current = root.getAttribute('data-theme');
          const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
          const effectiveIsDark = current ? current === 'dark' : prefersDark;
          root.setAttribute('data-theme', effectiveIsDark ? 'light' : 'dark');
        });
      })();
    </script>
  </body>
</html>
