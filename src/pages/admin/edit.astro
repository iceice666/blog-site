---
export const prerender = true;
import '../../styles/global.css';
import { author, site } from '../../../config';
import styles from '../../styles/Admin.module.css';
import shell from '../../styles/Shell.module.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href={author.avatar} />
    <title>Editor | {site.title}</title>
    <script is:inline>
      // Inline so the saved theme applies before first paint.
      try {
        var savedTheme = window.localStorage.getItem('blog:theme');
        if (savedTheme === 'light' || savedTheme === 'dark') {
          document.documentElement.setAttribute('data-theme', savedTheme);
        }
      } catch {}
    </script>
  </head>
  <body class={styles.body}>
    <div class={styles.app}>
      <header class={styles.topbar}>
        <a class={styles.brand} href="/">&larr; blog</a>
        <span class={styles.topbarLabel}>editor</span>
        <div class={styles.topbarRight}>
          <span data-editor-user></span>
          <button id="theme-toggle" class={shell.chip} type="button" aria-label="toggle color theme">theme</button>
        </div>
      </header>
      <main class={styles.main} data-admin-editor>
        <div class={styles.home}><p class={styles.status}>Loading editor...</p></div>
      </main>
    </div>

    <script>
      import '../../scripts/admin-editor';

      (function () {
        const root = document.documentElement;
        const btn = document.getElementById('theme-toggle');
        btn?.addEventListener('click', function () {
          const current = root.getAttribute('data-theme');
          const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
          const effectiveIsDark = current ? current === 'dark' : prefersDark;
          const next = effectiveIsDark ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try {
            window.localStorage.setItem('blog:theme', next);
          } catch {
            // Local storage can be unavailable in private or embedded contexts.
          }
        });
      })();
    </script>
  </body>
</html>
