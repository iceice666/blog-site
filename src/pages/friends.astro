---
export const prerender = true;
import Shell from '../layouts/Shell.astro';
import { renderInlineMarkdown } from '../lib/markdown';
import { friends, socialDisplayName, socialHref, socialIsExternal } from '../../config';

const renderedFriends = await Promise.all(
  friends.map(async (friend) => ({
    ...friend,
    descHtml: await renderInlineMarkdown(friend.desc),
  }))
);
---

<Shell title="Friends | Brian Duan" activeKey="friends" paneTitle="friends.md" wide>
  <h1>Friends</h1>
  <p class="friends-sub">Blogs and sites I like to read.</p>

  <div class="friends-grid">
    {
      renderedFriends.map((f) => (
        <div class="friend-card" lang="zh-tw">
          <a href={f.url} class="avatar friend-avatar" target="_blank" rel="noopener noreferrer">
            <img src={f.img} alt={f.name} loading="lazy" />
          </a>
          <div class="friend-body">
            <a href={f.url} class="friend-name" target="_blank" rel="noopener noreferrer">
              {f.name}
            </a>
            <div class="friend-desc" set:html={f.descHtml} />
            {f.socials.length > 0 && (
              <div class="friend-links">
                {f.socials.map((s) => (
                  <a
                    href={socialHref(s)}
                    target={socialIsExternal(s) ? '_blank' : undefined}
                    rel={socialIsExternal(s) ? 'noopener noreferrer' : undefined}
                  >
                    {socialDisplayName(s)}
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      ))
    }
  </div>
</Shell>
