---
export const prerender = true;
import Shell from '../layouts/Shell.astro';
import { getFeedItems, type FeedItem } from '../lib/content';
import styles from '../styles/Archive.module.css';

// Stub posts only link through to an article that already has its own row here.
const items = (await getFeedItems()).filter((item) => !item.isStub);

function stripTags(html?: string) {
  return (html ?? '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
}

function excerpt(item: FeedItem, len = 140) {
  const text = item.kind === 'ARTICLE' ? item.description : stripTags(item.bodyHtml);
  return text.length > len ? text.slice(0, len) + '…' : text;
}

function displayTitle(item: FeedItem) {
  return item.title ?? (excerpt(item, 70) || '(no subject)');
}

const groups = new Map<string, FeedItem[]>();
for (const item of items) {
  const key = item.publishedAt ? item.publishedAt.slice(0, 7) : 'undated';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(item);
}
const sortedKeys = [...groups.keys()].sort().reverse();
---

<Shell title="Archive | Brian Duan" activeKey="archive" paneTitle={`archive.md (${items.length} entries)`} wide>
  <h1>Archive</h1>
  <p class={styles.sub}>Every article and note, in one place — newest first.</p>

  <div class={styles.search}>
    <span class={styles.glyph}>/</span>
    <input
      id="archive-filter"
      type="text"
      placeholder="type to filter by title or tag"
      aria-label="filter entries by title or tag"
      autocomplete="off"
    />
    <span class={styles.count} id="archive-count" aria-live="polite">{items.length} entries</span>
  </div>

  <p id="archive-empty-state" class={styles.empty} style="display:none">No entries match that filter.</p>

  {
    sortedKeys.map((key) => {
      const [year, month] = key.split('-');
      const label = month ? `${year} / ${month}` : year;
      return (
        <>
          <div class={styles.group} data-archive-group>
            {label}
          </div>
          {groups.get(key)!.map((item) => {
            const search = [item.kind, displayTitle(item), excerpt(item, 300), ...item.tags]
              .join(' ')
              .toLowerCase();
            const dateShort = item.publishedAt ? item.publishedAt.slice(5) : '';
            return (
              <div
                class={styles.row}
                data-article={item.kind === 'ARTICLE' ? '' : undefined}
                data-note={item.kind === 'POST' ? '' : undefined}
                data-archive-row
                data-vim-target
                data-vim-open={item.href ?? undefined}
                data-search={search}
                lang={item.lang}
              >
                <span class={styles.kind}>{item.kind}</span>
                {item.href ? (
                  <a href={item.href} class={styles.title}>
                    {displayTitle(item)}
                  </a>
                ) : (
                  <span class={styles.title}>{displayTitle(item)}</span>
                )}
                <span class={styles.tags}>{item.tags.join(', ') || '—'}</span>
                <span class={styles.date}>{dateShort}</span>
              </div>
            );
          })}
        </>
      );
    })
  }

  <script>
    const input = document.getElementById('archive-filter');
    const rows = Array.from(document.querySelectorAll('[data-archive-row]'));
    const groupEls = Array.from(document.querySelectorAll('[data-archive-group]'));
    const countEl = document.getElementById('archive-count');
    const emptyEl = document.getElementById('archive-empty-state');
    const params = new URLSearchParams(window.location.search);

    if (input instanceof HTMLInputElement) {
      const applyFilter = () => {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        rows.forEach((row) => {
          const match = !q || (row.getAttribute('data-search') ?? '').includes(q);
          row.toggleAttribute('data-filter-hidden', !match);
          if (match) visible++;
        });
        groupEls.forEach((group) => {
          let el = group.nextElementSibling;
          let any = false;
          while (el && !el.hasAttribute('data-archive-group')) {
            if (el.hasAttribute('data-archive-row') && !el.hasAttribute('data-filter-hidden')) any = true;
            el = el.nextElementSibling;
          }
          group.toggleAttribute('data-filter-hidden', !any);
        });
        if (countEl) countEl.textContent = `${visible} entr${visible === 1 ? 'y' : 'ies'}`;
        if (emptyEl instanceof HTMLElement) emptyEl.style.display = visible === 0 ? 'block' : 'none';
      };

      input.value = params.get('tag') ?? params.get('q') ?? '';
      input.addEventListener('input', applyFilter);
      applyFilter();
    }
  </script>
</Shell>
