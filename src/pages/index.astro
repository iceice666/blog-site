---
export const prerender = true;
import { getCollection } from 'astro:content';
import ArticlePage from '../components/ArticlePage.astro';
import { DEFAULT_ARTICLE_LANG, getArticleAlternates } from '../lib/content';

const articles = await getCollection('articles');
const entry = articles.find((item) => item.id === `about/${DEFAULT_ARTICLE_LANG}`);

if (!entry) {
  throw new Error(`Missing about/${DEFAULT_ARTICLE_LANG} article for the home page.`);
}

const langAlternates = (await getArticleAlternates(entry.id)).map((item) =>
  item.isCurrent ? { ...item, href: '/' } : item
);
---

<ArticlePage entry={entry} activeKey="about" paneTitle={entry.id + '.mdx'} viewPath="/" langAlternates={langAlternates} />
