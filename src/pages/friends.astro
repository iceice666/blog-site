---
export const prerender = true;
import Shell from '../layouts/Shell.astro';
import { renderInlineMarkdown } from '../lib/markdown';
import { friends, socialDisplayName, socialHref, socialIsExternal } from '../../config';
import styles from '../styles/Friends.module.css';

const renderedFriends = await Promise.all(
  friends.map(async (friend) => ({
    ...friend,
    descHtml: await renderInlineMarkdown(friend.desc),
  }))
);
---

<Shell title="Friends | Brian Duan" activeKey="friends" paneTitle="friends.md" wide>
  <h1>Friends</h1>
  <p class={styles.sub}>Blogs and sites I like to read.</p>

  <div class={styles.grid}>
    {
      renderedFriends.map((f) => (
        <div class={styles.card} lang="zh-tw" data-vim-target data-vim-open={f.url}>
          <a href={f.url} class={styles.avatar} target="_blank" rel="noopener noreferrer">
            <img src={f.img} alt={f.name} loading="lazy" />
          </a>
          <div class={styles.body}>
            <a href={f.url} class={styles.name} target="_blank" rel="noopener noreferrer">
              {f.name}
            </a>
            <div class={styles.desc} set:html={f.descHtml} />
            {f.socials.length > 0 && (
              <div class={styles.links}>
                {f.socials.map((s) => (
                  <a
                    href={socialHref(s)}
                    target={socialIsExternal(s) ? '_blank' : undefined}
                    rel={socialIsExternal(s) ? 'noopener noreferrer' : undefined}
                  >
                    {socialDisplayName(s)}
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      ))
    }
  </div>
</Shell>
