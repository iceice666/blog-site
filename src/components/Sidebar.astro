---
import { PINNED_REPOS, type GithubData } from '../lib/github';
import type { BlogStats } from '../lib/content';
import { author, type SocialLink } from '../../config';

interface Props {
  windowIndex: number;
  stats: BlogStats;
  github: GithubData;
}
const { windowIndex, stats, github } = Astro.props;

function heatClass(level: number) {
  return level > 0 ? `l${level}` : '';
}

function linkOf(social: SocialLink) {
  return social.kind === 'email' ? `mailto:${social.address}` : social.url;
}
function labelOf(social: SocialLink) {
  return social.kind === 'email' ? 'mail' : social.kind === 'github' ? 'github' : 'site';
}
---

<aside class="sidebar">
  <div class="widget">
    <div class="pane-title">{windowIndex}.1 — whoami</div>
    <div class="widget-body profile">
      <div class="avatar">
        <img src={author.avatar} alt={author.name} loading="lazy" />
      </div>
      <div>
        <div class="profile-name">{author.name}</div>
        <div class="profile-tag">{author.tagline}</div>
      </div>
    </div>
    <div class="widget-body" style="padding-top:0">
      <div class="profile-links">
        {
          author.socials.map((social) => (
            <a href={linkOf(social)} target={social.kind === 'email' ? undefined : '_blank'} rel="noopener noreferrer">
              {labelOf(social)}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="widget">
    <div class="pane-title">{windowIndex}.2 — github activity</div>
    <div class="widget-body">
      <div class="heat-grid" aria-hidden="true">
        {github.heatmap.map((level) => <i class={heatClass(level)} />)}
      </div>
      <ul class="gh-activity">
        {
          github.activity.map((a) => (
            <li>
              <span class="ev">{a.ev}</span>
              <span>{a.repo}</span>
              <span class="when">{a.when}</span>
            </li>
          ))
        }
      </ul>
      <p class="gh-caption">
        {github.live ? 'live via GitHub public events API' : 'example data — live fetch unavailable at build time'}
      </p>
    </div>
  </div>

  <div class="widget">
    <div class="pane-title">{windowIndex}.3 — pinned repos</div>
    <div class="widget-body">
      {
        PINNED_REPOS.map((repo) => (
          <div class="repo-card">
            <div class="repo-name">{repo.name}</div>
            <p class="repo-desc">{repo.desc}</p>
            <div class="repo-lang">
              <i style={`background:var(${repo.langVar})`} />
              {repo.lang}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <div class="widget" style="border-bottom:none">
    <div class="pane-title">{windowIndex}.4 — stats</div>
    <div class="widget-body">
      <div class="stat-row"><dt>entries</dt><dd>{stats.entries}</dd></div>
      <div class="stat-row"><dt>articles</dt><dd>{stats.articles}</dd></div>
      <div class="stat-row"><dt>words</dt><dd>{stats.words.toLocaleString()}</dd></div>
      <div class="stat-row"><dt>langs</dt><dd>{stats.langs.join(' / ')}</dd></div>
      <div class="toptags">
        {stats.topTags.map((tag) => <span>{tag}</span>)}
      </div>
    </div>
  </div>
</aside>
