---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import Shell from '../layouts/Shell.astro';
import Comments from '../components/Comments.astro';
import { countUnits, getArticleSlug, inferLang, isAboutArticleId, readingTime, stripMarkdown } from '../lib/content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.filter((entry) => isAboutArticleId(entry.id)).map((entry) => {
    const slug = getArticleSlug(entry.id);
    return { params: { slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const langHref = entry.id === 'about-me' ? '/about-zh-tw' : entry.id === 'about-me.zh-tw' ? '/about' : null;

const lang = inferLang(entry.id, entry.data.lang, entry.body ?? '');
const units = countUnits(stripMarkdown(entry.body ?? ''));
const readMin = readingTime(units);
---

<Shell
  title={`${entry.data.title} | Brian Duan`}
  activeKey="about"
  paneTitle={`${entry.id}.mdx`}
  langHref={langHref}
  description={entry.data.description}
  lang={lang}
>
  <div class="art-meta">
    <span class="pill">ARTICLE</span>
    <span>{entry.data.category}</span>
    <span>{lang}</span>
    <span>{entry.data.publishedAt}</span>
  </div>
  <h1>{entry.data.title}</h1>
  <p class="art-desc">{entry.data.description}</p>
  <p class="art-stats">{units} words · {readMin} min read</p>
  <p class="art-tags">{entry.data.tags.map((t) => `#${t}`).join(' ')}</p>
  <hr class="art-rule" />

  <div class="prose" lang={lang}>
    <Content />
  </div>

  <Comments entryType="article" entryId={entry.id} title={entry.data.title} path={`/${getArticleSlug(entry.id)}`} />
</Shell>
