---
export const prerender = true;
import Shell from '../layouts/Shell.astro';
---

<Shell
  title="404 Not Found | Brian Duan"
  activeKey="about"
  extraWindow={{ label: '[No Name]' }}
  paneTitle="404.md"
>
  <div class="art-meta">
    <span class="pill pill-danger">404</span>
    <span>not found</span>
  </div>
  <h1>No such buffer</h1>
  <p class="art-desc">Whatever you were looking for isn't here — moved, renamed, or never existed.</p>
  <hr class="art-rule" />

  <div class="prose">
    <pre data-lang="shell"><code>$ cd <span id="attempted-path">…</span>
bash: cd: <span id="attempted-path-2">…</span>: No such file or directory</code></pre>

    <p>Try one of these instead:</p>
    <ul>
      <li><a href="/">~/about</a></li>
      <li><a href="/feed">~/feed</a> — everything, newest first</li>
      <li><a href="/friends">~/friends</a></li>
      <li><a href="/archive">~/archive</a> — or filter with <code>/</code> once you're there</li>
    </ul>
  </div>

  <script>
    const path = window.location.pathname;
    document.getElementById('attempted-path')?.replaceChildren(path);
    document.getElementById('attempted-path-2')?.replaceChildren(path);
  </script>
</Shell>
