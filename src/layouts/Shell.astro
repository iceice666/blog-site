---
import "../styles/global.css";
import { NAV_ITEMS, getBlogStats } from "../lib/content";
import { getGithubData } from "../lib/github";
import Sidebar from "../components/Sidebar.mdx";
import { author, site } from "../../config";

interface Props {
    title: string;
    activeKey: "feed" | "about" | "friends" | "archive" | "typography";
    extraWindow?: { label: string };
    paneTitle: string;
    langHref?: string | null;
    langAlternates?: Array<{
        lang: string;
        href: string;
        title?: string;
        isCurrent?: boolean;
    }>;
    description?: string;
    lang?: string;
    wide?: boolean;
    ogType?: "website" | "article";
}
const {
    title,
    activeKey,
    extraWindow,
    paneTitle,
    langHref = null,
    langAlternates = [],
    description = site.description,
    lang = "en",
    wide = false,
    ogType = "website",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(author.avatar, site.url).href;

const stats = await getBlogStats();
const github = await getGithubData();
const langSwitch =
    langAlternates.find((item) => !item.isCurrent) ??
    (langHref ? { lang: "en/zh", href: langHref } : null);

const extraWindowIndex =
    Math.max(...NAV_ITEMS.map((item) => item.windowIndex)) + 1;
---

<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/png" href={author.avatar} />
        <link rel="apple-touch-icon" href={author.avatar} />
        <link rel="canonical" href={canonicalUrl} />
        {
            langAlternates.map((item) => (
                <link
                    rel="alternate"
                    hreflang={item.lang}
                    href={new URL(item.href, site.url).href}
                />
            ))
        }
        <link
            rel="alternate"
            type="application/rss+xml"
            title={site.title}
            href="/rss.xml"
        />
        <meta property="og:type" content={ogType} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:site_name" content={site.title} />
        <meta property="og:image" content={ogImage} />
        <meta name="twitter:card" content="summary" />
        <title>{title}</title>
        <script is:inline>
            // Inline so the saved theme applies before first paint.
            try {
                var savedTheme = window.localStorage.getItem("blog:theme");
                if (savedTheme === "light" || savedTheme === "dark") {
                    document.documentElement.setAttribute(
                        "data-theme",
                        savedTheme,
                    );
                }
                var savedSidebar = window.localStorage.getItem(
                    "blog:sidebar-visible",
                );
                if (savedSidebar === "false") {
                    document.documentElement.setAttribute(
                        "data-sidebar",
                        "hidden",
                    );
                }
            } catch {}
        </script>
    </head>
    <body>
        <a class="skip-link" href="#main-content">skip to content</a>
        <div class="tmux">
            <div class="status-bar top">
                <div class="session">justaslime</div>
                <div class="windows">
                    {
                        NAV_ITEMS.map((item) => {
                            const isActive =
                                item.key === activeKey && !extraWindow;
                            return (
                                <a
                                    href={item.href}
                                    class={`win${isActive ? " active" : ""}`}
                                >
                                    {item.windowIndex}:{item.label}
                                    {isActive ? "*" : ""}
                                </a>
                            );
                        })
                    }
                    {
                        extraWindow && (
                            <span class="win active">
                                {extraWindowIndex}:{extraWindow.label}*
                            </span>
                        )
                    }
                </div>
                <div class="status-right">
                    <button
                        id="vim-toggle"
                        class="chip mode"
                        type="button"
                        aria-label="toggle Vim navigation"
                        aria-pressed="true">VIM ON</button
                    >
                    <button
                        id="theme-toggle"
                        class="chip"
                        type="button"
                        aria-label="toggle color theme">THEME</button
                    >
                    {
                        langSwitch ? (
                            <a href={langSwitch.href} class="chip">
                                {langSwitch.lang}
                            </a>
                        ) : (
                            <span class="chip" aria-disabled="true">
                                {lang}
                            </span>
                        )
                    }
                </div>
            </div>

            <div class="panes">
                <slot name="outline" />
                <div class="pane-main">
                    <div class="pane-title">{paneTitle}</div>
                    <div class="scroll-area">
                        <div
                            class={`reading${wide ? " is-wide" : ""}`}
                            id="main-content"
                            tabindex="-1"
                        >
                            <slot />
                        </div>
                    </div>
                </div>

                <Sidebar stats={stats} github={github} />
            </div>

            <div class="status-bar bottom">
                <span id="vim-status" class="vim-status" aria-hidden="true"
                    >-- NORMAL --</span
                >
                <span id="vim-status-announce" class="sr-only" aria-live="polite"
                ></span>
                <span class="vim-help">
                    <slot name="footer-hints">
                        <span>j/k move</span>
                        <span>gg/G top/bottom</span>
                        <span>/ search</span>
                        <span>:? help</span>
                    </slot>
                </span>
            </div>
        </div>

        <script>
            import "../scripts/umami";
            import "../scripts/vim-nav";

            // On desktop the page scrolls inside .scroll-area, which the
            // browser's native scroll restoration doesn't cover — restore it
            // ourselves on back/forward navigation.
            (function () {
                const scroller =
                    document.querySelector<HTMLElement>(".scroll-area");
                if (!scroller) return;
                const key = "blog:scroll:" + location.pathname;
                window.addEventListener("pagehide", function () {
                    try {
                        sessionStorage.setItem(key, String(scroller.scrollTop));
                    } catch {}
                });
                const nav = performance.getEntriesByType("navigation")[0] as
                    | PerformanceNavigationTiming
                    | undefined;
                if (nav?.type !== "back_forward") return;
                try {
                    const saved = sessionStorage.getItem(key);
                    if (saved) scroller.scrollTop = Number(saved);
                } catch {}
            })();

            (function () {
                const root = document.documentElement;
                const btn = document.getElementById("theme-toggle");
                btn?.addEventListener("click", function () {
                    const current = root.getAttribute("data-theme");
                    const prefersDark = window.matchMedia?.(
                        "(prefers-color-scheme: dark)",
                    ).matches;
                    const effectiveIsDark = current
                        ? current === "dark"
                        : prefersDark;
                    const next = effectiveIsDark ? "light" : "dark";
                    root.setAttribute("data-theme", next);
                    try {
                        window.localStorage.setItem("blog:theme", next);
                    } catch {
                        // Local storage can be unavailable in private or embedded contexts.
                    }
                });
            })();
        </script>
    </body>
</html>
