---
export const prerender = true;
import { getCollection } from 'astro:content';
import ArticlePage from '../components/ArticlePage.astro';
import { getArticleInfo, isStandaloneArticleId } from '../lib/content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.filter((entry) => isStandaloneArticleId(entry.id)).map((entry) => {
    return { params: { slug: getArticleInfo(entry.id).routeSlug }, props: { entry } };
  });
}

const { entry } = Astro.props;
---

<ArticlePage entry={entry} />
