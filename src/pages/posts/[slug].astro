---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import Shell from '../../layouts/Shell.astro';
import Comments from '../../components/Comments.astro';
import ViewCount from '../../components/ViewCount.astro';
import DocOutline from '../../components/DocOutline.astro';
import { countUnits, getPostArticleStubHref, getPostHref, getPostSlug, inferLang, readingTime, stripMarkdown } from '../../lib/content';

export async function getStaticPaths() {
  const [posts, articles] = await Promise.all([getCollection('posts'), getCollection('articles')]);

  return posts.filter((entry) => !getPostArticleStubHref(entry, articles)).map((entry) => {
    return { params: { slug: getPostSlug(entry.id) }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const outlineHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const slug = getPostSlug(entry.id);
const title = entry.data.title ?? entry.id;
const lang = inferLang(entry.id, entry.data.lang, entry.body ?? '');
const units = countUnits(stripMarkdown(entry.body ?? ''));
const readMin = readingTime(units);
const href = getPostHref(entry.id);
---

<Shell
  title={`${title} | Brian Duan`}
  activeKey="feed"
  extraWindow={{ label: `posts/${slug}` }}
  paneTitle={`${entry.id}.md`}
  description={entry.data.description}
  lang={lang}
  ogType="article"
>
  {outlineHeadings.length > 0 && <DocOutline slot="outline" headings={outlineHeadings} />}
  <div class="art-meta">
    <span class="pill pill-post">POST</span>
    <span>{lang}</span>
    <span>{entry.data.publishedAt}</span>
  </div>
  <h1>{title}</h1>
  <p class="art-stats">{units} words · {readMin} min read<ViewCount path={href} /></p>
  <hr class="art-rule" />

  <div class="prose" lang={lang}>
    <Content />
  </div>

  <Comments entryType="post" entryId={entry.id} title={title} path={href} />
</Shell>
