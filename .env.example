# Worker runtime env for self-hosted Umami tracking and readback.
# Example: https://umami.example.com/api
UMAMI_API_URL=
UMAMI_WEBSITE_ID=
UMAMI_DOMAINS=www.justaslime.dev
UMAMI_USERNAME=
UMAMI_PASSWORD=

# Optional alternative to UMAMI_USERNAME + UMAMI_PASSWORD if you already have a bearer token.
UMAMI_API_TOKEN=
