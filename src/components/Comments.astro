---
interface Props {
  entryType: 'article' | 'post';
  entryId: string;
  title: string;
  path: string;
}

const { entryType, entryId, title, path } = Astro.props;
const id = `comments-${entryType}-${entryId}`.replace(/[^\w-]/g, '-');
import styles from '../styles/Comments.module.css';
---

<section
  class={styles.comments}
  data-comments
  data-entry-type={entryType}
  data-entry-id={entryId}
  data-title={title}
  data-path={path}
  aria-labelledby={id}
>
  <div class={styles.commentsHead}>
    <div>
      <h2 id={id} class={styles.title} data-comments-title>comments</h2>
      <p class={styles.meta}>GitHub Discussions</p>
    </div>
  </div>
  <p class={styles.note} data-comments-status>Loading comments...</p>
</section>

<script>
  import '../scripts/comments';
</script>
