---
export const prerender = true;
import Shell from '../layouts/Shell.astro';
import ViewCount from '../components/ViewCount.astro';
import { getFeedItems, type FeedItem } from '../lib/content';
import styles from '../styles/Feed.module.css';
import content from '../styles/Content.module.css';
import '../styles/Markdown.module.css';

const items = await getFeedItems();

type ArticleFeedItem = FeedItem & { kind: 'ARTICLE'; href: string };

function isLongFormArticle(item: FeedItem): item is ArticleFeedItem {
  return item.kind === 'ARTICLE' && item.href?.startsWith('/articles/') === true;
}

const promotedArticle = items.find(isLongFormArticle);
const feedItems = promotedArticle ? items.filter((item) => item.id !== promotedArticle.id) : items;
const displayedItemCount = feedItems.length + (promotedArticle ? 1 : 0);
---

<Shell title="Feed | Brian Duan" activeKey="feed" paneTitle={`feed.md (${displayedItemCount} entries)`}>
  {
    promotedArticle && (
      <section
        class={styles.spotlight}
        aria-labelledby="spotlight-title"
        lang={promotedArticle.lang}
        data-vim-target
        data-vim-open={promotedArticle.href}
      >
        <div class={styles.spotKicker}>LATEST ARTICLE</div>
        <div class={styles.meta}>
          <span class={styles.pill}>ARTICLE</span>
          <span class={styles.category}>{promotedArticle.category}</span>
          <span>{promotedArticle.lang}</span>
          <span>{promotedArticle.publishedAt}</span>
        </div>
        <h1 id="spotlight-title">
          <a href={promotedArticle.href}>{promotedArticle.title}</a>
        </h1>
        <p class={styles.desc}>{promotedArticle.description}</p>
        <p class={styles.stats}>
          {promotedArticle.units} words · {promotedArticle.readMin} min read
          <ViewCount path={promotedArticle.href} />
        </p>
        <p class={styles.tags}>{promotedArticle.tags.map((t) => `#${t}`).join(' ')}</p>
      </section>
    )
  }

  {
    feedItems.map((item) =>
      item.kind === 'ARTICLE' ? (
        <article class={styles.entry} lang={item.lang} data-vim-target data-vim-open={item.href}>
          <div class={styles.meta}>
            <span class={styles.pill}>ARTICLE</span>
            <span class={styles.category}>{item.category}</span>
            <span>{item.lang}</span>
            <span>{item.publishedAt}</span>
          </div>
          <h2>
            <a href={item.href}>{item.title}</a>
          </h2>
          <p class={styles.desc}>{item.description}</p>
          <p class={styles.stats}>
            {item.units} words · {item.readMin} min read
            {item.href && <ViewCount path={item.href} />}
          </p>
          <p class={styles.tags}>{item.tags.map((t) => `#${t}`).join(' ')}</p>
        </article>
      ) : (
        <article class={styles.entry} data-post lang={item.lang} data-vim-target data-vim-open={item.href ?? undefined}>
          <div class={styles.meta}>
            <span class={styles.pill}>POST</span>
            <span>{item.publishedAt}</span>
            {item.href && <ViewCount path={item.href} prefix="" />}
            {item.href && (
              <a class={styles.permalink} href={item.href} aria-label={`Open ${item.title ?? 'post'}`}>
                {item.isStub ? 'READ ARTICLE →' : 'OPEN POST →'}
              </a>
            )}
          </div>
          {item.title && (
            <h2>
              <a href={item.href ?? undefined}>{item.title}</a>
            </h2>
          )}
          <div class={content.prose} lang={item.lang} set:html={item.bodyHtml} />
        </article>
      )
    )
  }
</Shell>
