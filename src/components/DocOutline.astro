---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}
const { headings } = Astro.props;
import styles from '../styles/DocOutline.module.css';
---

<aside class={styles.outline} data-doc-outline aria-label="On this page">
  <div class={styles.paneTitle}>outline</div>
  <nav class={styles.body}>
    <span class={styles.marker} data-doc-outline-marker aria-hidden="true"></span>
    {
      headings.map((h) => (
        <a
          class:list={[styles.link, h.depth === 2 ? styles.depth2 : styles.depth3]}
          href={`#${h.slug}`}
          data-doc-outline-link={h.slug}
        >
          {h.text}
        </a>
      ))
    }
  </nav>
</aside>
<script>
  import "../scripts/doc-outline";
</script>
